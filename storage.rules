rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Users can upload/read their own face images
    match /faces/{userId}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 10 * 1024 * 1024  // 10MB max
                   && request.resource.contentType.matches('image/.*');
    }

    // Output videos readable by owner, writable only by functions
    match /outputs/{userId}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false; // Only written by Cloud Functions
    }

    // Template preview videos - readable by authenticated users
    match /templates/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false; // Only writable via Admin SDK or Console
    }
  }
}
